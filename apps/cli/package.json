{
  "name": "@atlas-ai/cli",
  "version": "0.1.0",
  "private": true,
  "description": "Atlas AI CLI — first adapter into the core request pipeline",
  "type": "module",
  "bin": {
    "atlas": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node ./dist/main.js",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@atlas-ai/ai": "workspace:*",
    "@atlas-ai/config": "workspace:*",
    "@atlas-ai/core": "workspace:*",
    "@atlas-ai/database": "workspace:*",
    "@atlas-ai/filesystem": "workspace:*",
    "@atlas-ai/knowledge": "workspace:*",
    "@atlas-ai/logging": "workspace:*",
    "@atlas-ai/memory": "workspace:*",
    "@atlas-ai/platform": "workspace:*",
    "@atlas-ai/profile": "workspace:*",
    "@atlas-ai/security": "workspace:*",
    "@atlas-ai/workspace": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22",
    "typescript": "~5.8.3"
  }
}
