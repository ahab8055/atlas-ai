{
  "name": "@atlas-ai/config",
  "version": "0.1.0",
  "private": true,
  "description": "Centralized configuration loading for Atlas AI",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test:load": "pnpm build && node ./scripts/print.mjs"
  },
  "devDependencies": {
    "@types/node": "22",
    "typescript": "~5.8.3"
  }
}
