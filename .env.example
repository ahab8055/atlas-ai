# Atlas AI — local environment template
# Copy to `.env` for local development: `cp .env.example .env`
# Never commit `.env` — it may contain secrets.
#
# Loading order is documented in docs/guides/Configuration.md:
# defaults → config/{ATLAS_ENV}.json → config/{ATLAS_ENV}.local.json → .env → process env

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

# development | production | test
ATLAS_ENV=development

# error | warn | info | debug | trace
ATLAS_LOG_LEVEL=debug

# Rust tracing (desktop core) — see docs/guides/Logging.md
# RUST_LOG=info,atlas_desktop=debug

# -----------------------------------------------------------------------------
# Paths (relative to repo root unless absolute)
# -----------------------------------------------------------------------------

# Local app data (SQLite, caches, logs)
ATLAS_DATA_DIR=.data

# Local model weights directory (GGUF / llama.cpp assets)
ATLAS_MODELS_DIR=models

# SQLite database file
ATLAS_DATABASE_PATH=.data/atlas.db

# Optional bind address for local services
# ATLAS_HOST=127.0.0.1
# ATLAS_PORT=7420

# Feature flags (true | false)
# ATLAS_FEATURE_CLOUD_PROVIDERS=false
# ATLAS_FEATURE_TELEMETRY=false

# -----------------------------------------------------------------------------
# Local AI inference (optional overrides)
# -----------------------------------------------------------------------------

# ATLAS_AI_PROVIDER=mock
# ATLAS_AI_ENDPOINT=http://127.0.0.1:8080
# ATLAS_AI_DEFAULT_MODEL=mock-general
# ATLAS_AI_TEMPERATURE=0.7
# ATLAS_AI_MAX_TOKENS=256
# ATLAS_AI_CONTEXT_SIZE=4096
# ATLAS_AI_STREAM=true
# ATLAS_AI_ACCELERATION=cpu
# ATLAS_AI_GPU_LAYERS=0
# ATLAS_AI_MANAGE_SERVER=false

# -----------------------------------------------------------------------------
# Secrets (never put these in config/*.json)
# Optional cloud providers — leave empty for offline-first MVP
# Future MVP may also read these from the OS keychain.
# -----------------------------------------------------------------------------

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Desktop / public frontend only (safe to expose to the Vite client)
# Never put secret keys in VITE_* variables.
# -----------------------------------------------------------------------------

# VITE_ATLAS_API_URL=http://127.0.0.1:7420
