# Atlas AI — local environment template
# Copy to `.env` for local development: `cp .env.example .env`
# Never commit `.env` — it may contain secrets.

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

# development | production | test
ATLAS_ENV=development

# error | warn | info | debug | trace
ATLAS_LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Paths (relative to repo root unless absolute)
# -----------------------------------------------------------------------------

# Local app data (SQLite, caches, logs)
ATLAS_DATA_DIR=.data

# Local model weights directory (GGUF / llama.cpp assets)
ATLAS_MODELS_DIR=models

# SQLite database file
ATLAS_DATABASE_PATH=.data/atlas.db

# -----------------------------------------------------------------------------
# Optional cloud providers (local-first — leave empty for offline MVP)
# -----------------------------------------------------------------------------

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Desktop / Tauri (used once the desktop app is scaffolded)
# -----------------------------------------------------------------------------

# VITE_ATLAS_API_URL=http://127.0.0.1:7420
