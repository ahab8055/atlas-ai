{
  "name": "atlas-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Atlas AI — local-first personal AI assistant",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=9 <10"
  },
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "prepare": "husky",
    "check:env": "bash scripts/check-env.sh",
    "dev": "bash scripts/with-cargo-path.sh pnpm --filter @atlas-ai/desktop tauri:dev",
    "dev:web": "pnpm --filter @atlas-ai/desktop dev",
    "build": "pnpm packages:build && pnpm cli:build && pnpm --filter @atlas-ai/desktop build",
    "packages:build": "pnpm config:build && pnpm logging:build && pnpm security:build && pnpm database:build && pnpm ai:build && pnpm tools:build && pnpm core:build",
    "build:desktop": "bash scripts/with-cargo-path.sh pnpm --filter @atlas-ai/desktop tauri:build",
    "check:rust": "bash scripts/with-cargo-path.sh cargo check --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "preview": "pnpm --filter @atlas-ai/desktop preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:rust": "bash scripts/with-cargo-path.sh cargo fmt --all",
    "format:rust:check": "bash scripts/with-cargo-path.sh cargo fmt --all -- --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:rust": "bash scripts/with-cargo-path.sh cargo clippy --manifest-path apps/desktop/src-tauri/Cargo.toml --all-targets -- -D warnings",
    "check:quality": "pnpm format:check && pnpm lint && pnpm format:rust:check && pnpm lint:rust",
    "check": "pnpm check:quality && pnpm check:rust && pnpm build",
    "commitlint": "commitlint",
    "commitlint:last": "commitlint --last --verbose",
    "config:build": "pnpm --filter @atlas-ai/config build",
    "config:print": "pnpm --filter @atlas-ai/config test:load",
    "logging:build": "pnpm --filter @atlas-ai/logging build",
    "security:build": "pnpm --filter @atlas-ai/security build",
    "database:build": "pnpm --filter @atlas-ai/database build",
    "ai:build": "pnpm --filter @atlas-ai/ai build",
    "tools:build": "pnpm --filter @atlas-ai/tools build",
    "core:build": "pnpm --filter @atlas-ai/core build",
    "cli:build": "pnpm --filter @atlas-ai/cli build",
    "atlas": "node ./apps/cli/dist/main.js",
    "test": "pnpm packages:build && vitest run",
    "test:watch": "vitest",
    "test:coverage": "pnpm packages:build && vitest run --coverage",
    "test:integration": "pnpm packages:build && vitest run tests/integration",
    "test:rust": "bash scripts/with-cargo-path.sh cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "test:all": "pnpm test && pnpm test:rust"
  },
  "devDependencies": {
    "@atlas-ai/core": "workspace:*",
    "@atlas-ai/logging": "workspace:*",
    "@atlas-ai/security": "workspace:*",
    "@atlas-ai/tools": "workspace:*",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.30.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
